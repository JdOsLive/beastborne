		if ( raid == null ) return "";
		var species = MonsterManager.Instance?.GetSpecies( raid.BossSpeciesId );
		return species?.Description ?? "";
	}

	private string GetRaidBossRarity()
	{
		var raid = GuildManager.Instance?.CurrentRaidBoss;
		if ( raid == null ) return "Legendary";
		var species = MonsterManager.Instance?.GetSpecies( raid.BossSpeciesId );
		return species?.BaseRarity.ToString() ?? "Legendary";
