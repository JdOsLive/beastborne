	private static IEnumerable<T[]> ChunkArray<T>( T[] source, int size )
	{
		for ( int i = 0; i < source.Length; i += size )
		{
			var chunk = new T[Math.Min( size, source.Length - i )];
			Array.Copy( source, i, chunk, 0, chunk.Length );
			yield return chunk;
		}
	}

	protected override void OnAfterTreeRender( bool firstTime )
	{
		if ( firstTime )
		{
			if ( GuildManager.Instance != null )
			{
				GuildManager.Instance.OnGuildUpdated += OnRefresh;
				GuildManager.Instance.OnMembersUpdated += OnRefresh;
				GuildManager.Instance.OnLogUpdated += OnRefresh;
				GuildManager.Instance.OnGuildError += OnError;

				// Init emblem editor with current values
				if ( GuildManager.Instance.Guild != null )
				{
					emblemColor = GuildManager.Instance.Guild.EmblemColor;
					emblemIcon = GuildManager.Instance.Guild.EmblemIcon;
					emblemShape = GuildManager.Instance.Guild.EmblemShape;

					settingsJoinMode = GuildManager.Instance.Guild.JoinMode;
					settingsMinLevel = GuildManager.Instance.Guild.MinLevel;
					settingsMinRank = GuildManager.Instance.Guild.MinRank;
					settingsAutoKick = GuildManager.Instance.Guild.AutoKickInactive;
