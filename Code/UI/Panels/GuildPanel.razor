	private void OnAttackRaidBoss()
	{
		raidTeamSelection = new List<Monster>();
		showRaidTeamSelect = true;
		SoundManager.PlayForward();
	}

	private void ToggleRaidTeamMember( Monster monster )
	{
		if ( raidTeamSelection.Contains( monster ) )
			raidTeamSelection.Remove( monster );
		else if ( raidTeamSelection.Count < 3 )
			raidTeamSelection.Add( monster );
		SoundManager.PlayClick();
	}

	private List<Monster> GetRaidAvailableMonsters()
	{
		return MonsterManager.Instance?.OwnedMonsters
			?.OrderByDescending( m => m.Level ).ToList() ?? new List<Monster>();
	}

	private (string ComboName, float Multiplier) GetRaidComboPreview()
	{
		if ( raidTeamSelection.Count != 3 ) return ("None", 1f);
		return GuildManager.Instance?.CalculateComboBonus( raidTeamSelection ) ?? ("None", 1f);
	}

	private void StartRaidBattle()
	{
		if ( raidTeamSelection.Count == 0 ) return;
		showRaidTeamSelect = false;

		var gm = GuildManager.Instance;
		if ( gm == null || gm.CurrentRaidBoss == null ) return;

		var bossSpecies = MonsterManager.Instance?.GetSpecies( gm.CurrentRaidBoss.BossSpeciesId );
		if ( bossSpecies == null ) return;

		var raidBoss = new Monster
		{
			SpeciesId = gm.CurrentRaidBoss.BossSpeciesId,
			Nickname = gm.CurrentRaidBoss.BossName,
			Level = gm.CurrentRaidBoss.BossLevel
		};
		MonsterManager.Instance?.RecalculateStats( raidBoss );
		raidBoss.CurrentHP = 999999;
		raidBoss.MaxHP = 999999;

		// Start interactive raid battle via BattleManager
		BattleManager.Instance?.StartRaidBattle( raidTeamSelection, raidBoss, gm.CurrentRaidBoss.MaxRounds );
		showRaidBattle = true;
	}

	private void OnRaidBattleComplete( bool playerWon )
	{
		showRaidBattle = false;

		var bm = BattleManager.Instance;
		var gm = GuildManager.Instance;
		if ( bm == null || gm == null ) return;

		int rawDamage = bm.RaidDamageDealt;
		int roundsUsed = bm.RaidCurrentRound;

		var combo = gm.CalculateComboBonus( raidTeamSelection );

		gm.CompleteRaidAttempt( rawDamage, combo.Multiplier, combo.ComboName, roundsUsed );

		raidResultDamage = rawDamage;
		raidResultComboName = combo.ComboName;
		raidResultComboMultiplier = combo.Multiplier;
		raidResultScore = (int)(rawDamage * combo.Multiplier);
		showRaidResults = true;

		bm.ExitBattle();
		raidTeamSelection.Clear();
	}

	// Formatting
	private string FormatCooldown()
	{
		var remaining = GuildManager.Instance?.GetHopCooldownRemaining() ?? TimeSpan.Zero;
		if ( remaining.TotalHours >= 1 )
			return $"{(int)remaining.TotalHours}h {remaining.Minutes}m";
		return $"{remaining.Minutes}m";
	}

	private string FormatRaidTimer()
	{
		var end = GuildManager.Instance?.GetPeriodEndDate() ?? DateTime.UtcNow;
		var remaining = end - DateTime.UtcNow;
		if ( remaining.TotalDays >= 1 )
			return $"{(int)remaining.TotalDays}d {remaining.Hours}h";
		return $"{remaining.Hours}h {remaining.Minutes}m";
	}

	private string FormatLastSeen( DateTime lastSeen )
	{
		var days = (int)(DateTime.UtcNow - lastSeen).TotalDays;
		if ( days == 0 ) return "today";
		if ( days == 1 ) return "1d ago";
		return $"{days}d ago";
	}

	private string FormatLogTime( DateTime timestamp )
	{
		var diff = DateTime.UtcNow - timestamp;
		if ( diff.TotalMinutes < 60 ) return $"{(int)diff.TotalMinutes}m ago";
		if ( diff.TotalHours < 24 ) return $"{(int)diff.TotalHours}h ago";
		return $"{(int)diff.TotalDays}d ago";
	}

	private float GetGuildXPPercent()
	{
		var guild = GuildManager.Instance?.Guild;
		if ( guild == null ) return 0;
		var needed = GuildManager.GetXPForGuildLevel( guild.Level );
		if ( needed <= 0 ) return 100;
		return Math.Min( 100, (float)guild.GuildXP / needed * 100f );
	}

	private string GetEmblemEmoji( string icon )
	{
		return EmblemIcons.TryGetValue( icon, out var emoji ) ? emoji : "🛡️";
	}

	private string GetAvatarEmoji( GuildMemberInfo member )
	{
		return member.Role switch
		{
			GuildRole.Beastlord => "👑",
			GuildRole.Warden => "⭐",
			_ => "🧑"
		};
	}

	private string GetLogIcon( string action )
