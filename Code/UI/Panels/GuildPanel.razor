	private RaidAttemptResult GetMyBestRaidScore()
	{
		var raid = GuildManager.Instance?.CurrentRaidBoss;
		if ( raid?.BestScores == null ) return null;
		long steamId = (long)(Connection.Local?.SteamId ?? 0);
		raid.BestScores.TryGetValue( steamId, out var myBest );
		return myBest;
