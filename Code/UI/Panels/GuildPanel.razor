	// Raids — helpers
	private string GetRaidBossSpritePath()
	{
		var raid = GuildManager.Instance?.CurrentRaidBoss;
		if ( raid == null ) return "";
		var species = MonsterManager.Instance?.GetSpecies( raid.BossSpeciesId );
		if ( species?.AnimationFrames?.Count > 0 )
		{
			int frame = SpriteAnimator.GlobalFrame % species.AnimationFrames.Count;
			return species.AnimationFrames[frame];
		}
		return species?.IconPath ?? "";
	}

	private string GetElementAccentColor()
	{
		var raid = GuildManager.Instance?.CurrentRaidBoss;
		if ( raid == null ) return "#a855f7";
		return raid.BossElement switch
		{
			ElementType.Fire => "#ef4444",
			ElementType.Water => "#3b82f6",
			ElementType.Earth => "#b45309",
			ElementType.Wind => "#22c55e",
			ElementType.Electric => "#facc15",
			ElementType.Ice => "#93c5fd",
			ElementType.Nature => "#22c55e",
			ElementType.Metal => "#9ca3af",
			ElementType.Shadow => "#8b5cf6",
			ElementType.Spirit => "#ec4899",
			_ => "#a855f7"
		};
	}

	private string GetRaidBossDescription()
	{
