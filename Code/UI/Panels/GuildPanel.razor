	private void OnRefresh()
	{
		var guild = GuildManager.Instance?.Guild;
		if ( guild != null )
		{
			emblemColor = guild.EmblemColor;
			emblemIcon = guild.EmblemIcon;
			emblemShape = guild.EmblemShape;
			settingsJoinMode = guild.JoinMode;
			settingsMinLevel = guild.MinLevel;
			settingsMinRank = guild.MinRank;
			settingsAutoKick = guild.AutoKickInactive;
			settingsInactiveDays = guild.InactiveDays;
			settingsDescription = guild.Description ?? "";
		}
		else
		{
			settingsJoinMode = GuildJoinMode.Request;
			settingsMinLevel = 1;
			settingsMinRank = "Unranked";
			settingsAutoKick = false;
			settingsInactiveDays = 3;
			settingsDescription = "";
			guildView = "landing";
