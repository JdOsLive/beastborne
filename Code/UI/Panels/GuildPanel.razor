		SoundManager.PlayClick();
	}

	// Helpers
	private int GetTamerLevel() => TamerManager.Instance?.CurrentTamer?.Level ?? 0;

	private void ViewGuildDetail( GuildAdvertisement guild )
	{
		SoundManager.PlayForward();
		viewingGuild = guild;
	}

	private List<GuildAdvertisement> apiGuilds = new();
	private bool isLoadingGuilds = false;

	private List<GuildAdvertisement> GetVisibleGuilds()
	{
		// Combine RPC-discovered guilds (nearby) with API-fetched guilds (all)
		var rpcGuilds = GuildManager.Instance?.VisibleGuilds?.Values?.ToList() ?? new();
		var combined = new Dictionary<string, GuildAdvertisement>();

		// API guilds first (more complete data)
		foreach ( var g in apiGuilds )
			combined[g.GuildId] = g;

		// RPC guilds override (more up-to-date online counts)
		foreach ( var g in rpcGuilds )
			combined[g.GuildId] = g;

		return combined.Values.ToList();
	}

	private async void LoadGuildsFromApi()
	{
		if ( isLoadingGuilds ) return;
		isLoadingGuilds = true;

		var result = await (GuildManager.Instance?.BrowseGuildsFromApi() ?? Task.FromResult( new List<GuildAdvertisement>() ));
		apiGuilds = result;
		isLoadingGuilds = false;
	}

	private List<GuildMemberInfo> GetFilteredMembers()
	{
		var members = GuildManager.Instance?.Members ?? new List<GuildMemberInfo>();
		memberSearch = memberSearchInput?.Text ?? "";
		if ( string.IsNullOrWhiteSpace( memberSearch ) )
			return members;
		return members.Where( m => m.Name.Contains( memberSearch, StringComparison.OrdinalIgnoreCase ) ).ToList();
	}

	private bool IsInactive( GuildMemberInfo member )
	{
		var days = GuildManager.Instance?.Guild?.InactiveDays ?? 7;
		return !member.IsOnline && (DateTime.UtcNow - member.LastSeen).TotalDays >= days;
	}

